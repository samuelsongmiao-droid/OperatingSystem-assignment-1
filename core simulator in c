#include <stdio.h>
#include <string.h>
#include <time.h>

#define MAX 100

typedef enum {NEW, READY, RUNNING, WAITING, TERMINATED} State;

typedef struct {
    int pid, priority, burst, remain, memory, threads, parent, exit_code;
    State state;
    char name[50];
    time_t created;
} PCB;

PCB table[MAX];
int count = 0, next_pid = 1000;

char *state_name(State s)
{
    char *names[] = {"NEW","READY","RUNNING","WAITING","TERMINATED"};
    return names[s];
}

PCB* find(int pid)
{
    for(int i=0;i<count;i++)
        if(table[i].pid == pid) return &table[i];
    return NULL;
}

void log_msg(char *msg)
{
    printf("[%ld] %s\n", time(NULL), msg);
}

int edu_fork(PCB *parent)
{
    PCB child = *parent;

    child.pid = next_pid++;
    child.parent = parent->pid;
    child.state = READY;

    sprintf(child.name,"%s_child",parent->name);

    table[count++] = child;

    printf("fork(): %d -> %d\n", parent->pid, child.pid);

    return child.pid;
}

void edu_exec(int pid, char *prog)
{
    PCB *p = find(pid);

    if(!p) return;

    strcpy(p->name, prog);
    p->burst = p->remain = rand()%20+5;

    printf("exec(): PID %d running %s\n", pid, prog);
}

void edu_wait(int pid)
{
    PCB *p = find(pid);

    if(!p) return;

    p->state = WAITING;

    printf("wait(): PID %d waiting\n", pid);
}

void edu_exit(int pid, int code)
{
    PCB *p = find(pid);

    if(!p) return;

    p->state = TERMINATED;
    p->exit_code = code;
    p->remain = 0;

    printf("exit(): PID %d terminated\n", pid);
}

void edu_ps()
{
    printf("\nPID\tNAME\t\tSTATE\n");

    for(int i=0;i<count;i++)
        printf("%d\t%-10s\t%s\n",
               table[i].pid,
               table[i].name,
               state_name(table[i].state));
}

int main()
{
    PCB init = {
        .pid = next_pid++,
        .priority = 0,
        .burst = 10,
        .remain = 10,
        .memory = 1024,
        .threads = 1,
        .state = READY
    };

    strcpy(init.name,"init");

    table[count++] = init;

    int c1 = edu_fork(&table[0]);
    edu_exec(c1,"chrome.exe");

    int c2 = edu_fork(&table[0]);
    edu_exec(c2,"spotify.exe");

    edu_ps();

    edu_exit(c1,0);
    edu_wait(init.pid);
    edu_exit(c2,0);

    edu_ps();

    return 0;
}
